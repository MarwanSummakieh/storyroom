# Next.js web app (UI + REST API), production build.
#
# Used by docker-compose for the full local stack. For cloud, deploy this image
# to any container host or use Vercel directly (see docs/DEPLOY.md).
FROM node:22-slim AS base
WORKDIR /app
RUN corepack enable

# Install dependencies (postinstall runs `prisma generate`).
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc* ./
COPY prisma ./prisma
COPY prisma.config.ts ./
RUN pnpm install --frozen-lockfile --prod=false

# App source.
COPY . .

# NEXT_PUBLIC_* values are inlined at build time, so the realtime URL the
# browser connects to must be known here.
ARG NEXT_PUBLIC_COLLAB_URL=ws://localhost:1234
ENV NEXT_PUBLIC_COLLAB_URL=$NEXT_PUBLIC_COLLAB_URL

RUN pnpm build

ENV NODE_ENV=production
EXPOSE 3000
CMD ["pnpm", "start"]
