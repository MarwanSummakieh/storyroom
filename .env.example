# ─────────────────────────────────────────────────────────────
# Realtime collaboration server
# ─────────────────────────────────────────────────────────────
# URL the browser uses to reach the Hocuspocus server.
#   local:      ws://localhost:1234
#   production: wss://your-realtime-host.onrender.com
NEXT_PUBLIC_COLLAB_URL=ws://localhost:1234

# Port the realtime server listens on locally (hosts inject PORT instead).
COLLAB_PORT=1234

# ─────────────────────────────────────────────────────────────
# Persistence
# ─────────────────────────────────────────────────────────────
# The store backend is chosen automatically:
#   - DATABASE_URL unset -> JSON dev store (zero setup, single machine)
#   - DATABASE_URL set   -> Postgres via Prisma (required for the split deploy
#                           where the web app and realtime server run on
#                           separate hosts and must share state)
#
# Set the SAME DATABASE_URL on both the web app (Vercel) and the realtime host.
DATABASE_URL=postgresql://storyroom:storyroom@localhost:5432/storyroom?schema=public

# Only used by the JSON dev store (ignored when DATABASE_URL is set).
STORYROOM_DATA_DIR=./data
